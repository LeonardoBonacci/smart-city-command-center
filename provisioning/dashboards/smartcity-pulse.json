          "id": "organize",
          "options": {
            "renameByName": {
              "pm25": "PM2.5",
              "pm10": "PM10",
              "no2": "NO₂"
            }
          }
        }
      ]
    },
    {
      "id": 6,
      "title": "Station Map",
      "description": "Geomap showing sensor stations with AQI-based color coding from lat/lon tags",
      "type": "geomap",
      "gridPos": {
        "h": 10,
        "w": 12,
